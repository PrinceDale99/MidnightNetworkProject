{
  "name": "midnight-counter",
  "version": "1.0.0",
  "description": "Privacy-preserving counter contract on Midnight Network",
  "scripts": {
    "compile": "compactc contracts/counter.compact managed",
    "test": "node --experimental-vm-modules node_modules/.bin/jest --testPathPattern=tests/",
    "test:run": "node --experimental-vm-modules node_modules/.bin/jest --testPathPattern=tests/ --forceExit"
  },
  "devDependencies": {
    "@midnight-ntwrk/compact-runtime": "^0.15.0",
    "@types/jest": "^29.5.12",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.3",
    "typescript": "^5.4.5"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "extensionsToTreatAsEsm": [".ts"],
    "transform": {
      "^.+\\.tsx?$": ["ts-jest", { "useESM": true }]
    }
  }
}
