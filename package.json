{
  "name": "midnight-counter",
  "version": "1.0.0",
  "description": "ZK-Whistleblower — Anonymous fraud and ESG reporting on Midnight Network",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.app.json && vite build",
    "preview": "vite preview",
    "compile": "compact compile contracts/counter.compact managed",
    "test": "node --experimental-vm-modules node_modules/.bin/jest --testPathPattern=tests/",
    "test:run": "node --experimental-vm-modules node_modules/.bin/jest --testPathPattern=tests/ --forceExit"
  },
  "dependencies": {
    "@midnight-ntwrk/dapp-connector-api": "^1.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@midnight-ntwrk/compact-runtime": "^0.15.0",
    "@types/jest": "^29.5.12",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.3",
    "typescript": "^5.4.5",
    "vite": "^5.3.4",
    "vite-plugin-node-polyfills": "^0.22.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "extensionsToTreatAsEsm": [".ts"],
    "transform": {
      "^.+\\.tsx?$": ["ts-jest", { "useESM": true }]
    }
  }
}
